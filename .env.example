# Copy to .env for local tooling (optional). Docker Compose sets vars inline.

JWT_SECRET=dev-secret-change-me
INTERNAL_API_KEY=dev-internal-key

USER_SVC_URL=http://localhost:3001
SHOP_SVC_URL=http://localhost:3002
ORDER_SVC_URL=http://localhost:3003

# Checkout: use Azure Service Bus when set; otherwise use CHECKOUT_TRANSPORT=http
# SERVICEBUS_CONNECTION_STRING=
# SERVICEBUS_TOPIC=checkout-events
CHECKOUT_TRANSPORT=http

# OpenTelemetry (api-gateway and optional services)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-collector
# OTEL_SERVICE_NAME=api-gateway

# Rate limit (api-gateway)
# RATE_LIMIT_TTL_SEC=60
# RATE_LIMIT_MAX=120
