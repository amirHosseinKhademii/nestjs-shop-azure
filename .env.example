# Copy to .env for local tooling (optional). Docker Compose sets vars inline.

# user-svc — pick ONE style:

# Neon (recommended for demos): create env files once, then paste your URL.
#   pnpm run init:user-env
# That copies this file → .env and apps/user-svc/.env.example → apps/user-svc/.env.
# Put DATABASE_URL in either .env (root) or apps/user-svc/.env (Neon path uses /neondb).
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-HOST.neon.tech/neondb?sslmode=require
# If Node prints an sslmode forward-compat warning, append: &uselibpqcompat=true
# (see pg-connection-string / libpq SSL mode notes). Optional: PGSSL=true for non-URL TLS only.

# Or discrete vars (Docker / Azure Flexible Server):
# PGHOST=localhost
# PGUSER=postgres
# PGPASSWORD=postgres
# USER_DB=user_app
# PGPORT=5432
# PGSSL=true


JWT_SECRET=dev-secret-change-me
INTERNAL_API_KEY=dev-internal-key

USER_SVC_URL=http://localhost:3001
SHOP_SVC_URL=http://localhost:3002
ORDER_SVC_URL=http://localhost:3003

# Checkout: use Azure Service Bus when set; otherwise use CHECKOUT_TRANSPORT=http
# SERVICEBUS_CONNECTION_STRING=
# SERVICEBUS_TOPIC=checkout-events
CHECKOUT_TRANSPORT=http

# OpenTelemetry (api-gateway and optional services)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-collector
# OTEL_SERVICE_NAME=api-gateway

# Rate limit (api-gateway)
# RATE_LIMIT_TTL_SEC=60
# RATE_LIMIT_MAX=120
