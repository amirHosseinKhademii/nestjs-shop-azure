{
  "title": "Business — checkout & orders",
  "uid": "shop-business-checkout",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "checkout_published_total rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (transport, result) (rate(checkout_published_total[5m]))",
          "legendFormat": "{{transport}} {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "orders_created_total rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (result) (rate(orders_created_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "order_checkout_handle_seconds (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, source) (rate(order_checkout_handle_seconds_bucket[5m])))",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "kafka_consumer_lag_seconds (gauge)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "kafka_consumer_lag_seconds",
          "legendFormat": "lag",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] }
}
