{
  "title": "Kubernetes — workload overview (shop)",
  "uid": "shop-k8s-overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "description": "Lightweight workload view derived from scraped app + node metrics. For full cluster/node dashboards, start from Grafana.com dashboard **7249** and adapt to your Mimir labels.",
  "panels": [
    {
      "type": "timeseries",
      "title": "Node CPU (unix exporter)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "avg by (instance) (rate(node_cpu_seconds_total{mode!=\"idle\"}[5m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node memory available ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP traffic (all shop services)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(shop_http_request_duration_seconds_count[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] }
}
