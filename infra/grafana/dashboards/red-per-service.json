{
  "title": "RED — shop HTTP",
  "uid": "shop-red-http",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(shop_http_request_duration_seconds_count[5m]))",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx rate / all",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(shop_http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(shop_http_request_duration_seconds_count[5m]))",
          "legendFormat": "ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency (s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(shop_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] }
}
