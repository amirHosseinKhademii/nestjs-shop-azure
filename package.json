{
  "name": "shop-nest-azure",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "pnpm": {
    "overrides": {
      "glob": ">=10.5.0",
      "lodash": ">=4.18.0",
      "multer": ">=2.1.0",
      "picomatch": ">=4.0.4"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "init:user-env": "sh scripts/init-user-env.sh",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "dev:gateway": "pnpm --filter @shop/api-gateway start:dev",
    "dev:user": "pnpm --filter @shop/user-svc start:dev",
    "dev:shop": "pnpm --filter @shop/shop-svc start:dev",
    "dev:order": "pnpm --filter @shop/order-svc start:dev",
    "dev:web": "pnpm --filter @shop/web dev",
    "audit": "pnpm audit --audit-level=moderate"
  }
}
