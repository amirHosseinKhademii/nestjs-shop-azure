{
  "name": "shop-nest-azure",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "pnpm": {
    "overrides": {
      "glob": ">=10.5.0",
      "lodash": ">=4.18.0",
      "multer": ">=2.1.0",
      "picomatch": ">=4.0.4"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"apps/*/src/**/*.{ts,tsx,css}\" \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"apps/*/src/**/*.{ts,tsx,css}\" \"packages/*/src/**/*.ts\"",
    "verify": "pnpm run format:check && turbo run lint typecheck test",
    "check": "pnpm run verify && turbo run build",
    "ci": "pnpm run check",
    "build:shared": "turbo run build --filter=@shop/shared",
    "build:services": "turbo run build --filter=@shop/api-gateway --filter=@shop/user-svc --filter=@shop/shop-svc --filter=@shop/order-svc",
    "lint:services": "turbo run lint --filter='./apps/*-svc' --filter=@shop/api-gateway",
    "typecheck:services": "turbo run typecheck --filter='./apps/*-svc' --filter=@shop/api-gateway",
    "test:services": "turbo run test --filter='./apps/*-svc' --filter=@shop/api-gateway",
    "verify:services": "pnpm run format:check && turbo run lint typecheck test --filter='./apps/*-svc' --filter=@shop/api-gateway",
    "check:services": "pnpm run verify:services && pnpm run build:services",
    "ci:services": "pnpm run check:services",
    "dev:gateway": "pnpm --filter @shop/api-gateway start:dev",
    "dev:user": "pnpm --filter @shop/user-svc start:dev",
    "dev:shop": "pnpm --filter @shop/shop-svc start:dev",
    "dev:order": "pnpm --filter @shop/order-svc start:dev",
    "dev:web": "pnpm --filter @shop/web dev",
    "dev:services": "turbo run start:dev --filter='./apps/*-svc' --filter=@shop/api-gateway",
    "dev": "turbo run start:dev dev --filter='./apps/*'",
    "dev:all": "turbo run start:dev dev --filter='./apps/*'",
    "audit": "pnpm audit --audit-level=moderate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "kafkajs": "^2.2.4",
    "prettier": "^3.4.2",
    "turbo": "^2.9.7",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
